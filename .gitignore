# Python
__pycache__/
*.py[cod]
.venv/
.ipynb_checkpoints/

# SQLite transient files — NOTE: data/worldcup.db itself IS committed (shared artifact)
*.db-journal
*.db-wal
*.db-shm

# Secrets — defensive only; by design no .env ever exists inside the repo tree
.env

# macOS
.DS_Store

# Office lock/temp files (e.g. ~$worldcup_tables.xlsx when the workbook is open)
~$*

# Manual Excel backups
reports/*_backup_*.xlsx

# Local EDA / data-profiling scratch (notebooks + helpers; not part of the pipeline)
dq_eda/
