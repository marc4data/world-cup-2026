{
  // Use the project virtualenv for everything (matches requirements.txt + CI).
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  // src/ modules import each other as top-level (import db, import config, ...);
  // tell the analyzer src/ is an import root so those resolve (no false squiggles).
  "python.analysis.extraPaths": ["src"],
  "python.autoComplete.extraPaths": ["src"],

  // Test discovery -> pytest over tests/.
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests"],

  // Keep the tree clean.
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ipynb_checkpoints": true
  }
}
